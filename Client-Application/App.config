<?xml version="1.0" encoding="utf-8" ?>
<configuration>

  <system.serviceModel>

    <bindings>
      <basicHttpBinding>
        <binding name="BasicHttpConfig"
                 maxReceivedMessageSize="10485760"
                 receiveTimeout="00:02:00"
                 sendTimeout="00:02:00">
          <security mode="None" />
        </binding>
      </basicHttpBinding>
    </bindings>

    <client>
      <!--
        This endpoint must match the WCF service host address exactly.
        If you change the port in the service, update it here too.
      -->
      <endpoint name="ExchangeServiceEndpoint"
                address="http://localhost:8080/ExchangeService"
                binding="basicHttpBinding"
                bindingConfiguration="BasicHttpConfig"
                contract="CurrencyExchangeClient.Services.IExchangeService" />
    </client>

  </system.serviceModel>

  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>

</configuration>
