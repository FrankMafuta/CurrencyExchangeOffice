<UserControl x:Class="CurrencyExchangeClient.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CurrencyExchangeClient.Converters"
             Background="{StaticResource BgDark}">

	<UserControl.Resources>
		<conv:StringNotEmptyToVisibilityConverter x:Key="StringToVis"/>
		<conv:BooleanToVisibilityConverter x:Key="BoolToVis"/>
	</UserControl.Resources>

	<Grid Margin="24,20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- CONTROLS -->
		<Grid Grid.Row="0" Margin="0,0,0,16">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="140"/>
				<ColumnDefinition Width="24"/>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="140"/>
				<ColumnDefinition Width="24"/>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="140"/>
				<ColumnDefinition Width="24"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>

			<TextBlock Grid.Column="0" Text="Currency" Style="{StaticResource Muted}" VerticalAlignment="Center"/>
			<TextBox Grid.Column="1" Style="{StaticResource DarkTextBox}"
                     Text="{Binding CurrencyCode, UpdateSourceTrigger=PropertyChanged}"/>

			<TextBlock Grid.Column="3" Text="From" Style="{StaticResource Muted}" VerticalAlignment="Center"/>
			<DatePicker Grid.Column="4" SelectedDate="{Binding StartDate}"/>

			<TextBlock Grid.Column="6" Text="To" Style="{StaticResource Muted}" VerticalAlignment="Center"/>
			<DatePicker Grid.Column="7" SelectedDate="{Binding EndDate}"/>

			<Button Grid.Column="9"
                    Content="Load History"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding LoadCommand}"
                    Height="36"/>
		</Grid>

		<!-- SUMMARY -->
		<Border Grid.Row="1"
                Margin="0,0,0,12"
                Background="{StaticResource BgPanel}"
                CornerRadius="6"
                Padding="16,10"
                Visibility="{Binding SummaryText, Converter={StaticResource StringToVis}}">

			<TextBlock Text="{Binding SummaryText}"
                       Style="{StaticResource Body}"
                       Foreground="{StaticResource Accent}"/>
		</Border>

		<!-- STATUS -->
		<TextBlock Grid.Row="2"
                   Text="{Binding StatusMessage}"
                   Style="{StaticResource Muted}"
                   Margin="0,0,0,10"/>

		<!-- DATA GRID -->
		<DataGrid Grid.Row="3"
                  ItemsSource="{Binding Rates}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

			<DataGrid.Columns>
				<DataGridTextColumn Header="Date" Binding="{Binding EffectiveDate}" Width="120"/>
				<DataGridTextColumn Header="Code" Binding="{Binding CurrencyCode}" Width="70"/>
				<DataGridTextColumn Header="Currency" Binding="{Binding CurrencyName}" Width="*"/>
				<DataGridTextColumn Header="Mid Rate" Binding="{Binding MidRate}" Width="140"/>
				<DataGridTextColumn Header="Buy Rate" Binding="{Binding BuyRate}" Width="110"/>
				<DataGridTextColumn Header="Sell Rate" Binding="{Binding SellRate}" Width="110"/>
			</DataGrid.Columns>
		</DataGrid>

		<!-- LOADING -->
		<Grid Grid.Row="3"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
			<Border Background="#AA0D1B2A">
				<TextBlock Text="⏳ Loading..."
                           Style="{StaticResource H2}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
			</Border>
		</Grid>

	</Grid>
</UserControl>