<UserControl x:Class="CurrencyExchangeClient.Views.RatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CurrencyExchangeClient.Converters"
             Background="{StaticResource BgDark}">

	<UserControl.Resources>
		<conv:BooleanToVisibilityConverter x:Key="BoolToVis"/>
	</UserControl.Resources>

	<Grid Margin="24,20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- TOOLBAR -->
		<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
			<TextBlock Text="Exchange Rates"
                       Style="{StaticResource H2}"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"/>

			<Button Content="Load All Rates"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding LoadAllRatesCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
		</StackPanel>

		<!-- SEARCH BAR -->
		<Grid Grid.Row="1" Margin="0,0,0,12">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="160"/>
				<ColumnDefinition Width="140"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<TextBox Grid.Column="0"
                     Style="{StaticResource DarkTextBox}"
                     Text="{Binding SearchCode, UpdateSourceTrigger=PropertyChanged}"
                     Tag="Currency code (e.g. USD)">
				<TextBox.InputBindings>
					<KeyBinding Key="Return" Command="{Binding SearchRateCommand}"/>
				</TextBox.InputBindings>
			</TextBox>

			<Button Grid.Column="1"
                    Content="Search"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding SearchRateCommand}"
                    Margin="10,0,0,0"/>

			<!-- RESULT PILL -->
			<Border Grid.Column="2"
                    Margin="16,0,0,0"
                    Background="{StaticResource BgPanel}"
                    CornerRadius="6"
                    Padding="16,0"
                    Visibility="{Binding SelectedRate, Converter={StaticResource BoolToVis}}">

				<StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">

					<TextBlock Margin="0,0,20,0"
                               Style="{StaticResource Body}">
						<Run Text="{Binding SelectedRate.CurrencyCode}" FontWeight="Bold"
                             Foreground="{StaticResource Accent}"/>
						<Run Text=" — "/>
						<Run Text="{Binding SelectedRate.CurrencyName}"/>
					</TextBlock>

					<TextBlock Margin="0,0,20,0">
						<Run Text="Mid: " Foreground="{StaticResource TextMuted}"/>
						<Run Text="{Binding SelectedRate.MidRate, StringFormat=N4}"/>
					</TextBlock>

					<TextBlock Margin="0,0,20,0">
						<Run Text="Buy: " Foreground="{StaticResource TextMuted}"/>
						<Run Text="{Binding SelectedRate.BuyRate, StringFormat=N4}" Foreground="#FF4CAF50"/>
					</TextBlock>

					<TextBlock>
						<Run Text="Sell: " Foreground="{StaticResource TextMuted}"/>
						<Run Text="{Binding SelectedRate.SellRate, StringFormat=N4}" Foreground="{StaticResource Danger}"/>
					</TextBlock>

				</StackPanel>
			</Border>
		</Grid>

		<!-- STATUS -->
		<TextBlock Grid.Row="2"
                   Text="{Binding StatusMessage}"
                   Style="{StaticResource Muted}"
                   Margin="0,0,0,10"/>

		<!-- DATA GRID -->
		<DataGrid Grid.Row="3"
                  ItemsSource="{Binding Rates}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column">

			<DataGrid.Columns>
				<DataGridTextColumn Header="Code" Binding="{Binding CurrencyCode}" Width="70"/>
				<DataGridTextColumn Header="Currency" Binding="{Binding CurrencyName}" Width="*"/>
				<DataGridTextColumn Header="Mid Rate (PLN)" Binding="{Binding MidRate}" Width="130"/>
				<DataGridTextColumn Header="Buy Rate" Binding="{Binding BuyRate}" Width="110"/>
				<DataGridTextColumn Header="Sell Rate" Binding="{Binding SellRate}" Width="110"/>
				<DataGridTextColumn Header="Date" Binding="{Binding EffectiveDate}" Width="120"/>
			</DataGrid.Columns>
		</DataGrid>

		<!-- BUSY OVERLAY -->
		<Grid Grid.Row="3"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
			<Border Background="#AA0D1B2A" CornerRadius="8">
				<TextBlock Text="⏳ Loading..."
                           Style="{StaticResource H2}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
			</Border>
		</Grid>

	</Grid>
</UserControl>