<?xml version="1.0" encoding="utf-8" ?>
<configuration>

  <system.serviceModel>

    <!-- ── SERVICE DEFINITION ──────────────────────────────────────────────── -->
    <services>
      <service name="CurrencyExchangeOffice.WcfService.ExchangeService"
               behaviorConfiguration="ServiceBehavior">

        <!--
          BasicHttpBinding endpoint — accessible by any HTTP client including
          older .NET Framework clients and the WPF client application.
          Address: http://localhost:8080/ExchangeService
        -->
        <endpoint address=""
                  binding="basicHttpBinding"
                  bindingConfiguration="BasicHttpConfig"
                  contract="CurrencyExchangeOffice.WcfService.IExchangeService" />

        <!--
          MEX (Metadata Exchange) endpoint — allows Visual Studio to generate
          a service reference automatically via "Add Service Reference".
          Address: http://localhost:8080/ExchangeService/mex
        -->
        <endpoint address="mex"
                  binding="mexHttpBinding"
                  contract="IMetadataExchange" />

   
      </service>
    </services>

    <!-- ── BINDING CONFIGURATION ────────────────────────────────────────────── -->
    <bindings>
      <basicHttpBinding>
        <binding name="BasicHttpConfig"
                 maxReceivedMessageSize="10485760"
                 receiveTimeout="00:02:00"
                 sendTimeout="00:02:00"
                 openTimeout="00:01:00"
                 closeTimeout="00:01:00">
          <security mode="None" />
          <!-- No authorization required, as per lab specification -->
        </binding>
      </basicHttpBinding>
    </bindings>

    <!-- ── SERVICE BEHAVIOUR ─────────────────────────────────────────────────── -->
    <behaviors>
      <serviceBehaviors>
        <behavior name="ServiceBehavior">
          <!-- Exposes WSDL at ?wsdl — required for service reference generation -->
          <serviceMetadata httpGetEnabled="true" />
          <!-- Returns detailed exception info in development — disable in production -->
          <serviceDebug includeExceptionDetailInFaults="true" />
        </behavior>
      </serviceBehaviors>
    </behaviors>

  </system.serviceModel>

  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>

</configuration>
